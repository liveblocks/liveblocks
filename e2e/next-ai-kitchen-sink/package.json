{
  "name": "@liveblocks/next-ai-kitchen-sink",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3008",
    "build": "next build",
    "start": "next start --port 3008",
    "lint": "next lint",
    "format": "(eslint --fix app/ test/ || true) && prettier --write app/ test/",
    "test": "playwright test --max-failures=1",
    "test:headed": "playwright --max-failures=1 test --headed",
    "test:ui": "playwright test --max-failures=1 --workers=1 --ui"
  },
  "dependencies": {
    "@liveblocks/client": "workspace:*",
    "@liveblocks/core": "workspace:*",
    "@liveblocks/node": "workspace:*",
    "@liveblocks/react": "workspace:*",
    "@liveblocks/react-ui": "workspace:*",
    "next": "16.1.4",
    "radix-ui": "^1.4.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "dotenv": "^16.0.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.1.18",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.4",
    "playwright": "^1.55.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
