{
  "name": "@liveblocks/next-sandbox",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "lint": "eslint pages/ utils/ test/",
    "format": "(eslint --fix pages/ utils/ test/ || true) && prettier --write pages/ utils/ test/",
    "test": "playwright test --max-failures=1",
    "test:headed": "playwright test --max-failures=1 --headed",
    "test:ui": "playwright test --max-failures=1 --workers=1 --ui",
    "dev": "next dev --port 3007",
    "start": "next start --port 3007"
  },
  "dependencies": {
    "@liveblocks/client": "workspace:*",
    "@liveblocks/core": "workspace:*",
    "@liveblocks/node": "workspace:*",
    "@liveblocks/react": "workspace:*",
    "@liveblocks/react-ui": "workspace:*",
    "@liveblocks/redux": "workspace:*",
    "@liveblocks/yjs": "workspace:*",
    "@liveblocks/zustand": "workspace:*",
    "@reduxjs/toolkit": "^2.8.2",
    "encoding": "^0.1.13",
    "next": "16.1.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^4.1.2",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "yjs": "^13.6.27",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "dotenv": "^16.0.0",
    "@eslint/compat": "^2.0.1",
    "@eslint/eslintrc": "^3.3.3",
    "@liveblocks/eslint-config": "workspace:*",
    "@playwright/test": "^1.55.0",
    "@types/lodash": "^4.17.13",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.4",
    "lodash": "^4.17.21",
    "playwright": "^1.55.0",
    "typescript": "^5.9.3"
  }
}
