# https://liveblocks.io/dashboard/apikeys
LIVEBLOCKS_SECRET_KEY=

# Adding the two below eanbles the AI assistant 

# --- Optional: AI assistant (@-mentions, create issue tool) ---
# When unset, the AI user is hidden from assignees and mention search.
# Webhook URL (Liveblocks dashboard): https://<your-host>/api/ai-comment-reply
# Event: commentCreated
LIVEBLOCKS_WEBHOOK_SECRET_KEY=

# Anthropic API key
ANTHROPIC_API_KEY=

# Optional: comma-separated hostnames for Next.js dev cross-origin (non-ngrok tunnels).
# Ngrok hosts are allowed by default in next.config.ts (*.ngrok-free.app, *.ngrok.io).
# NEXT_DEV_ALLOWED_ORIGINS=my-host.loca.lt
