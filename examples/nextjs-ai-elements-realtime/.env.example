# Your Liveblocks secret key, from https://liveblocks.io/dashboard/apikeys
LIVEBLOCKS_SECRET_KEY=sk_xxx

# Optional: enables real LLM replies via the Vercel AI Gateway.
# Get one at https://vercel.com/docs/ai-gateway
# If unset, the example uses a built-in mock assistant so it still runs.
AI_GATEWAY_API_KEY=
