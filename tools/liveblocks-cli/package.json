{
  "name": "liveblocks",
  "version": "1.4.1",
  "description": "Liveblocks command line interface",
  "type": "module",
  "bin": {
    "liveblocks": "dist/index.js"
  },
  "files": [
    "dist/**",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "bun ./dist/index.js dev -v",
    "add-license-headers": "eslint --fix 'src/**/*.{ts,tsx}' 'test/**/*.{ts,tsx}'",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'test/**/*.{ts,tsx}'",
    "lint:package": "publint --strict && attw --pack",
    "format": "eslint --fix src/ test/ ; prettier --write src/ test/",
    "test": "bun test",
    "test:types": "tsc --noEmit"
  },
  "license": "AGPL-3.0-or-later",
  "author": "Liveblocks Inc.",
  "keywords": [
    "Liveblocks",
    "CLI",
    "local",
    "development",
    "deploy"
  ],
  "sideEffects": false,
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@liveblocks/eslint-config": "workspace:*",
    "bun-types": "^1.3.9",
    "eslint": "^9.39.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-license-header": "^0.9.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "fast-check": "^3.23.2",
    "itertools": "^2.3.2",
    "prettier": "^3.3.2",
    "publint": "^0.3.17",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@liveblocks/core": "3.18.0",
    "@liveblocks/query-parser": "workspace:^",
    "@liveblocks/server": "workspace:^",
    "@liveblocks/zenrouter": "^1.0.17",
    "decoders": "^2.9.0",
    "js-base64": "^3.7.5",
    "yjs": "^13.6.10"
  }
}
