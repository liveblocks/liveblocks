{
  "name": "@liveblocks/wasm",
  "version": "0.1.0",
  "private": true,
  "description": "Liveblocks Rust core compiled to WebAssembly",
  "type": "module",
  "main": "./pkg/liveblocks_wasm.js",
  "types": "./pkg/liveblocks_wasm.d.ts",
  "files": [
    "pkg/**"
  ],
  "scripts": {
    "build": "wasm-pack build --target bundler --release",
    "test": "cargo test && wasm-pack test --headless --chrome",
    "lint": "cargo clippy -- -D warnings && cargo fmt --check"
  }
}
